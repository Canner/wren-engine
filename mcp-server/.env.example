# =============================================================================
# Wren MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Core (required)
# -----------------------------------------------------------------------------

# URL of the Wren ibis-server (host:port, no scheme)
WREN_URL=localhost:8000

# Absolute path to the connection info JSON file for your data source
# See README for the required fields per data source type.
CONNECTION_INFO_FILE=/path/to/connection_info.json

# Absolute path to the MDL JSON file to pre-load on startup (optional)
# If not set, MDL must be deployed at runtime via the 'deploy' tool.
MDL_PATH=/path/to/mdl.json

# MCP transport: "stdio" (default, for desktop clients) or "sse" (for HTTP)
# MCP_TRANSPORT=stdio

# Host and port used only when MCP_TRANSPORT=sse
# MCP_HOST=0.0.0.0
# MCP_PORT=9000

# -----------------------------------------------------------------------------
# MDL Agent (optional — requires `just install-mdl-agent`)
# -----------------------------------------------------------------------------

# LLM model string passed to pydantic-ai.
# Format: "<provider>:<model-name>"
# Examples:
#   anthropic:claude-3-5-sonnet-latest
#   openai:gpt-4o
#   google-gla:gemini-2.0-flash
# PYDANTIC_AI_MODEL=anthropic:claude-3-5-sonnet-latest

# API keys for your chosen LLM provider (only the relevant one is needed)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ibis-server endpoint for MDL dry-plan validation (usually same host as WREN_URL)
# WREN_ENGINE_ENDPOINT=http://localhost:8000

# Directory containing *.md / *.txt skill files loaded at startup.
# Skills provide domain knowledge (naming conventions, patterns, etc.) that the
# agent selects from semantically on each turn.
# MDL_AGENT_SKILLS_DIR=./skills

# JSON file path for persistent cross-session memory.
# The agent can read/write entries during a conversation and they survive restarts.
# MDL_AGENT_MEMORY_PATH=~/.wren/memory.json

# Maximum number of skills injected per turn (TF-IDF semantic ranking, default 5)
# MDL_AGENT_MAX_SKILLS=5
