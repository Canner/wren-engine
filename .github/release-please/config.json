{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "group-pull-request-title-pattern": "chore${scope}: release ${version}",
  "include-component-in-tag": false,
  "include-v-in-tag": false,
  "packages": {
    ".": {
      "package-name": "wren-engine",
      "component": "wren-engine",
      "release-type": "maven",
      "exclude-paths": ["ibis-server", "wren-modeling-rs", "wren-modeling-py"]
    },
    "./ibis-server": {
      "package-name": "ibis-server",
      "component": "ibis-server",
      "release-type": "python"
    },
    "./wren-modeling-rs": {
      "package-name": "wren-modeling-rs",
      "component": "wren-modeling-rs",
      "release-type": "rust"
    }
  },
  "plugins": [
    {
      "type": "maven-workspace",
      "merge": false
    },
    {
      "type": "cargo-workspace",
      "merge": false
    },
    {
      "type": "linked-versions",
      "groupName": "wren",
      "components": [
        "wren-engine",
        "ibis-server",
        "wren-modeling-rs"
      ]
    }
  ]
}
