# LLM Provider API Keys (set the one matching your chosen model)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Wren ibis-server endpoint for MDL dry-plan validation
# If not set, validate_mdl will only run JSON Schema validation
WREN_ENGINE_ENDPOINT=http://localhost:8000
